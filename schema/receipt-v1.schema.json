{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/repropack/receipt-v1.schema.json",
  "title": "ReproPack Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "replayed_at",
    "workdir",
    "command_display",
    "status",
    "recorded_exit_code",
    "observed_exit_code",
    "matched",
    "drift",
    "notes",
    "stdout_path",
    "stderr_path"
  ],
  "properties": {
    "schema_version": { "const": "repropack.receipt.v1" },
    "packet_id": { "type": "string" },
    "replayed_at": { "type": "string" },
    "workdir": { "type": "string" },
    "command_display": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["matched", "mismatched", "skipped", "blocked", "error"]
    },
    "recorded_exit_code": { "type": ["integer", "null"] },
    "observed_exit_code": { "type": ["integer", "null"] },
    "matched": { "type": "boolean" },
    "drift": {
      "type": "array",
      "items": { "$ref": "#/$defs/driftItem" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stdout_path": { "type": ["string", "null"] },
    "stderr_path": { "type": ["string", "null"] }
  },
  "$defs": {
    "driftItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["subject", "severity"],
      "properties": {
        "subject": { "type": "string" },
        "expected": { "type": ["string", "null"] },
        "observed": { "type": ["string", "null"] },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "error"]
        }
      }
    }
  }
}
